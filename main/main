async function startGame(d){
  diff=d;
  document.getElementById('intro').classList.add('hidden');
  document.getElementById('hud').style.display='flex';
  hp=50;collectedClues=[];doorsAnswered=0;
  initDoors();buildUI();
  const s=findT(2);
  player.x=s.c*TILE+TILE/2;player.y=s.r*TILE+TILE/2;
  gameRunning=true;
  await loadQ();
  requestAnimationFrame(loop);
}

// ═══════════════════════
// COLLISION
// ═══════════════════════
function collides(x,y){
  const h=PSIZE/2;
  for(const[cx,cy] of [[x-h,y-h],[x+h,y-h],[x-h,y+h],[x+h,y+h]]){
    const c=Math.floor(cx/TILE),r=Math.floor(cy/TILE);
    if(isWall(r,c)) return true;
    if(isDoor(r,c)&&!doorOpen(r,c)) return true;
  }
  return false;
}

function nearestDoor(x,y){
  const bc=Math.round(x/TILE),br=Math.round(y/TILE);
  for(let dr=-1;dr<=1;dr++) for(let dc=-1;dc<=1;dc++){
    const r=br+dr,c=bc+dc,t=gt(r,c);
    if(t>=4&&t<=13){
      const door=doors[t-4];
      if(door&&!door.opened){
        const dx=x-(c*TILE+TILE/2),dy=y-(r*TILE+TILE/2);
        if(Math.sqrt(dx*dx+dy*dy)<TILE*1.5) return door;
      }
    }
  }
  return null;
}

function atEnd(x,y){
  const e=findT(3);
  const dx=x-(e.c*TILE+TILE/2),dy=y-(e.r*TILE+TILE/2);
  return Math.sqrt(dx*dx+dy*dy)<TILE*0.85;
}

