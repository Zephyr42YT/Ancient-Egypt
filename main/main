// ═══════════════════════
// ANIMATED BG SCENES
// ═══════════════════════
const SCENES=[
  (c,w,h,t)=>{ // 0 desert night
    let g=c.createLinearGradient(0,0,0,h);g.addColorStop(0,'#03061a');g.addColorStop(1,'#180e02');
    c.fillStyle=g;c.fillRect(0,0,w,h);
    for(let i=0;i<90;i++){const sx=(i*137.5)%w,sy=(i*97.3)%(h*0.55),br=0.2+0.7*Math.abs(Math.sin(t*1.2+i));c.fillStyle=`rgba(255,255,220,${br*0.65})`;c.beginPath();c.arc(sx,sy,0.7,0,Math.PI*2);c.fill();}
