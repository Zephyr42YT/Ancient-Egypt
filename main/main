let diff='easy',hp=50,gameRunning=false;
let questions=[],doors=[],collectedClues=[];
let finalWord='',clueHints=[];
let nearDoor=null,activeDoor=null,qAnswered=false,doorsAnswered=0;
let player={x:0,y:0};
const SPEED=2.5,PSIZE=13,keys={};
let camX=0,camY=0,torchT=0;
let bgT=0,bgAnim=null;

