function showDeath(){
  gameRunning=false;
  document.getElementById('endscreen').classList.remove('hidden');
  document.getElementById('eicon').textContent='💀';
  document.getElementById('escore').textContent='YOU PERISHED';
  document.getElementById('escore').style.color='#cc2828';
  document.getElementById('emsg').textContent=`The pyramid has consumed you. You passed ${doorsAnswered} of 10 passages and collected ${collectedClues.filter(Boolean).length} fragments. The sands swallow your name.`;
}
function showWin(){
  const got=collectedClues.filter(Boolean).length;
  document.getElementById('endscreen').classList.remove('hidden');
  document.getElementById('eicon').textContent='☀️';
  document.getElementById('escore').textContent='YOU ESCAPED!';
  document.getElementById('emsg').textContent=`The final seal shatters. Sunlight floods the chamber. You gathered ${got} of 10 fragments and escaped with ${hp} HP remaining. The gods engrave your name in gold.`;
}

// ═══════════════════════
// DRAW CRACKS (door visual)
// ═══════════════════════
function drawCracks(ctx,tx,ty,seed,glow){
  const cx=tx+TILE/2,cy=ty+TILE/2;
  ctx.save();ctx.strokeStyle=`rgba(201,160,48,${glow})`;ctx.lineWidth=0.7;
  [(seed*53)%360,(seed*89+120)%360,(seed*131+240)%360].forEach(a=>{
    const rad=a*Math.PI/180,len=5+(seed%4);
    ctx.beginPath();ctx.moveTo(cx,cy);
    ctx.lineTo(cx+Math.cos(rad)*len*0.45+Math.sin(rad*1.7)*2.5,cy+Math.sin(rad)*len*0.45+Math.cos(rad*1.3)*2.5);
    ctx.lineTo(cx+Math.cos(rad)*len+Math.sin(rad*2.3)*2,cy+Math.sin(rad)*len+Math.cos(rad*2.1)*2);
    ctx.stroke();
  });
  if(glow>0.04){const dot=ctx.createRadialGradient(cx,cy,0,cx,cy,3.5);dot.addColorStop(0,`rgba(201,160,48,${glow*0.7})`);dot.addColorStop(1,'transparent');ctx.fillStyle=dot;ctx.beginPath();ctx.arc(cx,cy,3.5,0,Math.PI*2);ctx.fill();}
  ctx.restore();
}

// ═══════════════════════
// DRAW
// ═══════════════════════
function draw(){
  ctx.fillStyle='#030200';ctx.fillRect(0,0,canvas.width,canvas.height);
  const ox=Math.round(camX),oy=Math.round(camY);
  const sc=Math.max(0,Math.floor(-ox/TILE)-1),ec=Math.min(COLS,sc+Math.ceil(canvas.width/TILE)+3);
  const sr=Math.max(0,Math.floor(-oy/TILE)-1),er=Math.min(ROWS,sr+Math.ceil(canvas.height/TILE)+3);

  for(let r=sr;r<er;r++){
    for(let c=sc;c<ec;c++){
      const t=RMAP[r][c],tx=c*TILE+ox,ty=r*TILE+oy;
      if(t===0){
        ctx.fillStyle='#120c04';ctx.fillRect(tx,ty,TILE,TILE);
        ctx.fillStyle='#1a1208';ctx.fillRect(tx,ty,TILE,1);ctx.fillRect(tx,ty,1,TILE);
        ctx.fillStyle='#070401';ctx.fillRect(tx+TILE-1,ty,1,TILE);ctx.fillRect(tx,ty+TILE-1,TILE,1);
        if((r*COLS+c)%5===0){ctx.fillStyle='rgba(0,0,0,0.2)';ctx.fillRect(tx+TILE/2,ty,1,TILE);}
        if((r*COLS+c)%7===0){ctx.fillStyle='rgba(0,0,0,0.15)';ctx.fillRect(tx,ty+TILE/2,TILE,1);}
      } else if(t===1||t===2||t===3){
        ctx.fillStyle=(r+c)%2===0?'#090600':'#0b0700';ctx.fillRect(tx,ty,TILE,TILE);
        if(t===2){ctx.fillStyle='rgba(45,95,18,0.1)';ctx.fillRect(tx,ty,TILE,TILE);}
        if(t===3){
          const fl=0.55+0.45*Math.sin(torchT*2.2);
          ctx.fillStyle=`rgba(201,160,48,${0.07*fl})`;ctx.fillRect(tx,ty,TILE,TILE);
          ctx.strokeStyle=`rgba(201,160,48,${0.38*fl})`;ctx.lineWidth=1;ctx.strokeRect(tx+2,ty+2,TILE-4,TILE-4);
          ctx.fillStyle=`rgba(201,160,48,${0.45*fl})`;ctx.font='13px serif';ctx.textAlign='center';ctx.fillText('𓂀',tx+TILE/2,ty+TILE/2+5);
        }
      } else if(t>=4&&t<=13){
        ctx.fillStyle=(r+c)%2===0?'#090600':'#0b0700';ctx.fillRect(tx,ty,TILE,TILE);
        const door=doors[t-4];
        if(door&&!door.opened){const pulse=0.035+0.025*Math.sin(torchT*1.6+(t*0.8));drawCracks(ctx,tx,ty,t,pulse);}
        else if(door&&door.opened){drawCracks(ctx,tx,ty,t,0.012);}
      }
    }
  }

  // Player light
  const pgx=player.x+ox,pgy=player.y+oy;
  const fl=0.82+0.18*Math.sin(torchT*3.2);
  const lg=ctx.createRadialGradient(pgx,pgy,0,pgx,pgy,TILE*4.5*fl);
  lg.addColorStop(0,'rgba(201,160,48,0.07)');lg.addColorStop(0.45,'rgba(155,85,12,0.025)');lg.addColorStop(1,'transparent');
  ctx.fillStyle=lg;ctx.fillRect(0,0,canvas.width,canvas.height);

  // Vignette
  const vg=ctx.createRadialGradient(pgx,pgy,TILE*1.6,pgx,pgy,TILE*8.5);
  vg.addColorStop(0,'transparent');vg.addColorStop(1,'rgba(0,0,0,0.9)');
  ctx.fillStyle=vg;ctx.fillRect(0,0,canvas.width,canvas.height);

  // Player
  const pg=ctx.createRadialGradient(pgx,pgy,0,pgx,pgy,PSIZE*2);
  pg.addColorStop(0,'rgba(201,160,48,0.32)');pg.addColorStop(1,'transparent');
  ctx.fillStyle=pg;ctx.beginPath();ctx.arc(pgx,pgy,PSIZE*2,0,Math.PI*2);ctx.fill();
  ctx.fillStyle='#c9a030';ctx.beginPath();ctx.arc(pgx,pgy,PSIZE/2,0,Math.PI*2);ctx.fill();
  ctx.fillStyle='#fff3cc';ctx.beginPath();ctx.arc(pgx,pgy,PSIZE/4.5,0,Math.PI*2);ctx.fill();
}

// ═══════════════════════
// MINIMAP
// ═══════════════════════
function drawMini(){
  const mw=mini.width,mh=mini.height,tw=mw/COLS,th=mh/ROWS;
  mctx.fillStyle='rgba(3,2,0,0.88)';mctx.fillRect(0,0,mw,mh);
  for(let r=0;r<ROWS;r++) for(let c=0;c<COLS;c++){
    const t=RMAP[r][c];
    if(t===0){mctx.fillStyle='#201408';mctx.fillRect(c*tw,r*th,tw,th);}
    else if(t===3){mctx.fillStyle='#c9a030';mctx.fillRect(c*tw,r*th,tw,th);}
    else if(t>=4&&t<=13){
      const d=doors[t-4];
      // Barely distinguishable from floor — slightly warmer
      mctx.fillStyle=d&&d.opened?'#0b0800':'#181008';
      mctx.fillRect(c*tw,r*th,tw,th);
    }
  }
  const px=(player.x/TILE)*tw,py=(player.y/TILE)*th;
  mctx.fillStyle='#c9a030';mctx.beginPath();mctx.arc(px,py,2,0,Math.PI*2);mctx.fill();
  mctx.strokeStyle='rgba(201,160,48,0.22)';mctx.lineWidth=1;mctx.strokeRect(0,0,mw,mh);
}

// ═══════════════════════
// GAME LOOP
// ═══════════════════════
let last=0;
function loop(ts){
  const dt=Math.min((ts-last)/16.67,3);last=ts;torchT+=0.016*dt;
  if(gameRunning){
    let dx=0,dy=0;
    if(keys['w']||keys['arrowup']) dy=-1;
    if(keys['s']||keys['arrowdown']) dy=1;
    if(keys['a']||keys['arrowleft']) dx=-1;
    if(keys['d']||keys['arrowright']) dx=1;
    if(dx&&dy){dx*=0.707;dy*=0.707;}
    const nx=player.x+dx*SPEED*dt,ny=player.y+dy*SPEED*dt;
    if(!collides(nx,player.y)) player.x=nx;
    if(!collides(player.x,ny)) player.y=ny;
    camX=Math.round(canvas.width/2-player.x);camY=Math.round(canvas.height/2-player.y);
    nearDoor=nearestDoor(player.x,player.y);
    document.getElementById('dprompt').style.display=nearDoor?'block':'none';
    if(atEnd(player.x,player.y)){gameRunning=false;document.getElementById('dprompt').style.display='none';setTimeout(showFinal,300);}
  }
  draw();drawMini();requestAnimationFrame(loop);
}

// Touch
let tx0=0,ty0=0;
canvas.addEventListener('touchstart',e=>{tx0=e.touches[0].clientX;ty0=e.touches[0].clientY;});
canvas.addEventListener('touchmove',e=>{
  const dx=e.touches[0].clientX-tx0,dy=e.touches[0].clientY-ty0;
  keys['a']=dx<-12;keys['d']=dx>12;keys['w']=dy<-12;keys['s']=dy>12;
  e.preventDefault();
},{passive:false});
canvas.addEventListener('touchend',()=>{
  keys['a']=keys['d']=keys['w']=keys['s']=false;
  if(nearDoor&&!activeDoor) openQ(nearDoor);
});
</script>
</body>
</html>
