// ═══════════════════════
window.addEventListener('keydown',e=>{
  keys[e.key.toLowerCase()]=true;
  if(e.key.toLowerCase()==='g'&&nearDoor&&!activeDoor) openQ(nearDoor);
});
window.addEventListener('keyup',e=>keys[e.key.toLowerCase()]=false);

// ═══════════════════════
// BG ANIMATION
// ═══════════════════════
function startBgAnim(idx){
  bgT=0;qbg.classList.add('show');
  function frame(){bgT+=0.016;qctx.clearRect(0,0,qbg.width,qbg.height);SCENES[idx%SCENES.length](qctx,qbg.width,qbg.height,bgT);bgAnim=requestAnimationFrame(frame);}
  if(bgAnim) cancelAnimationFrame(bgAnim);
  frame();
}
function stopBgAnim(){if(bgAnim){cancelAnimationFrame(bgAnim);bgAnim=null;}qbg.classList.remove('show');}

// ═══════════════════════
// QUESTION
// ═══════════════════════
function openQ(door){
  if(door.answered) return;
  activeDoor=door;qAnswered=false;gameRunning=false;
  startBgAnim(door.doorIndex);
  const q=questions[door.doorIndex]||questions[0];
  document.getElementById('qdoor').textContent=`PASSAGE ${door.doorIndex+1} OF 10`;
  document.getElementById('qtext').textContent=q.question;
  const grid=document.getElementById('qgrid');grid.innerHTML='';
  ['A','B','C','D'].forEach((ltr,i)=>{
    const btn=document.createElement('button');btn.className='qbtn';
    btn.innerHTML=`<span class="qltr">${ltr}</span>${q.answers[i]}`;
    btn.onclick=()=>handleQ(i,q.correct,door);
    grid.appendChild(btn);
  });
  document.getElementById('qfb').textContent='';document.getElementById('qfb').className='qfb';
  document.getElementById('cluebox').classList.remove('show');
  document.getElementById('qmodal').classList.add('open');
}

function handleQ(sel,correct,door){
  if(qAnswered) return;
  qAnswered=true;door.answered=true;door.opened=true;doorsAnswered++;
  const btns=document.querySelectorAll('.qbtn');btns.forEach(b=>b.disabled=true);
  const fb=document.getElementById('qfb');
  if(sel===correct){
    btns[sel].classList.add('correct');
    fb.textContent='✓  THE PASSAGE YIELDS — A FRAGMENT IS YOURS';
    fb.className='qfb cfb';
    collectedClues[door.doorIndex]=door.clue;
    updateClueUI(door.doorIndex,door.clue);
    document.getElementById('cluewordbig').textContent=door.clue;
    document.getElementById('cluebox').classList.add('show');
  } else {
    btns[sel].classList.add('wrong');btns[correct].classList.add('correct');
    fb.textContent='✗  WRONG — THE SANDS PUNISH YOU  (-10 HP)';
    fb.className='qfb wfb';
    hp=Math.max(0,hp-10);updateHp();
    if(hp<=0){setTimeout(()=>{closeQ();showDeath();},1800);return;}
  }
  updateHudMid(`PASSAGE ${door.doorIndex+1} CLEARED`);
  setTimeout(closeQ,2400);
}

function closeQ(){
  document.getElementById('qmodal').classList.remove('open');
  stopBgAnim();activeDoor=null;gameRunning=true;
}

function updateHp(){
  const pct=hp/50;
  document.getElementById('hpfill').style.width=(pct*100)+'%';
  document.getElementById('hpfill').style.background=pct>0.6?'#c9a030':pct>0.3?'#cc5820':'#cc2020';
  document.getElementById('hpn').textContent=hp;
}

// ═══════════════════════
// FINAL
// ═══════════════════════
function showFinal(){
  gameRunning=false;
  const hints=document.getElementById('fhints');hints.innerHTML='';
  clueHints.forEach(h=>{const el=document.createElement('div');el.className='fhint-item';el.innerHTML=`<span>∴ </span>${h}`;hints.appendChild(el);});
  const fc=document.getElementById('fclues');fc.innerHTML='';
  for(let i=0;i<10;i++){
    const tag=document.createElement('div');
    if(collectedClues[i]){tag.className='fctag';tag.textContent=collectedClues[i];}
    else{tag.className='fctag miss';tag.textContent='???';}
    fc.appendChild(tag);
  }
  document.getElementById('ferr').textContent='';
  document.getElementById('finput').value='';document.getElementById('finput').classList.remove('err');
  document.getElementById('fmodal').classList.add('open');
}

function checkFinal(){
  const val=document.getElementById('finput').value.trim().toUpperCase();
  if(val===finalWord){document.getElementById('fmodal').classList.remove('open');showWin();}
  else{
    const inp=document.getElementById('finput');
    inp.classList.remove('err');void inp.offsetWidth;inp.classList.add('err');
    document.getElementById('ferr').textContent='✗  THE SEAL HOLDS — THAT IS NOT THE WORD';
  }
}
document.getElementById('finput').addEventListener('keydown',e=>{if(e.key==='Enter') checkFinal();});

