function resize(){canvas.width=window.innerWidth;canvas.height=window.innerHeight;qbg.width=window.innerWidth;qbg.height=window.innerHeight;}
resize();window.addEventListener('resize',resize);

// ═══════════════════════
// MAP HELPERS
// ═══════════════════════
const gt=(r,c)=>(r<0||r>=ROWS||c<0||c>=COLS)?0:RMAP[r][c];
const isWall=(r,c)=>gt(r,c)===0;
const isDoor=(r,c)=>{const t=gt(r,c);return t>=4&&t<=13;};
const doorOpen=(r,c)=>{const d=doors.find(d=>d.row===r&&d.col===c);return d?d.opened:false;};
function findT(v){for(let r=0;r<ROWS;r++) for(let c=0;c<COLS;c++) if(RMAP[r][c]===v) return{r,c}; return null;}

// ═══════════════════════
// INIT
// ═══════════════════════
function initDoors(){
  doors=[];
  for(let r=0;r<ROWS;r++) for(let c=0;c<COLS;c++){
    const t=RMAP[r][c];
    if(t>=4&&t<=13) doors.push({row:r,col:c,doorIndex:t-4,opened:false,clue:'',answered:false});
  }
  doors.sort((a,b)=>a.doorIndex-b.doorIndex);
}

function buildUI(){
  const pips=document.getElementById('cpips');pips.innerHTML='';
  for(let i=0;i<10;i++){const p=document.createElement('div');p.className='cpip';p.id=`cp${i}`;pips.appendChild(p);}
  const panel=document.getElementById('cpanel');panel.innerHTML='';
  for(let i=0;i<10;i++){const t=document.createElement('div');t.className='ctag';t.id=`ct${i}`;t.textContent='???';panel.appendChild(t);}
}

function updateClueUI(i,word){
  const cp=document.getElementById(`cp${i}`),ct=document.getElementById(`ct${i}`);
  if(cp) cp.classList.add('got');
  if(ct){ct.textContent=word;ct.classList.add('got');}
}

function updateHudMid(txt){ document.getElementById('hudmid').textContent=txt; }

// ═══════════════════════
// API
// ═══════════════════════
async function loadQ(){
  const dd={
    easy:'beginner — Nile, pharaohs, pyramids, mummies, hieroglyphics, basic gods.',
    medium:'intermediate — specific pharaohs, mythology, mummification, Rosetta Stone, architecture.',
    hard:'advanced — obscure pharaohs, detailed mythology, hieroglyphic specifics, ancient science and trade.'
  };
  const prompt=`You are making content for an Ancient Egypt maze game.

Create a secret word puzzle:
- Pick one Ancient Egypt concept word (5-8 letters, uppercase) as the FINAL ANSWER
- Generate exactly 10 Egypt-related clue words (gods, places, pharaohs, symbols, objects)
- Encode the final word using AT LEAST 2 of these 3 methods mixed together (no labels):
  A) First letters of certain clue words spell part of the final answer
  B) Certain clue words contain a hidden substring of the final answer inside them
  C) Certain clue words are thematic synonyms/attributes of the final answer concept
- Write exactly 3 cryptic poetic hints — ancient-sounding, NO direct method explanation
- Also generate 10 multiple choice questions about Ancient Egypt at ${dd[diff]}

Return ONLY valid JSON, no markdown:
{
  "finalWord":"SPHINX",
  "clues":["WORD1","WORD2","WORD3","WORD4","WORD5","WORD6","WORD7","WORD8","WORD9","WORD10"],
  "crypticHints":["hint1","hint2","hint3"],
  "questions":[{"question":"...","answers":["A","B","C","D"],"correct":0}]
}`;
  try{
    const res=await fetch('https://api.anthropic.com/v1/messages',{
      method:'POST',headers:{'Content-Type':'application/json'},
      body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:1800,messages:[{role:'user',content:prompt}]})
    });
    const data=await res.json();
    const raw=data.content[0].text.replace(/```json|```/g,'').trim();
    const p=JSON.parse(raw);
    questions=p.questions.slice(0,10);
    finalWord=p.finalWord.toUpperCase();
    clueHints=p.crypticHints||[];
    p.clues.slice(0,10).forEach((cl,i)=>{if(doors[i]) doors[i].clue=cl.toUpperCase();});
  }catch(e){console.warn('fallback',e);fallback();}
}

function fallback(){
  finalWord='ANUBIS';
  clueHints=['Where three names begin, the first truth is buried...','Inside the great guardian a syllable sleeps unseen...','The last five watchers all speak of the same dark shepherd...'];
  const cls=['AMUN','NILE','USHABTI','BASTET','IBIS','SPHINX','CANOPIC','OSIRIS','PAPYRUS','SCARAB'];
  doors.forEach((d,i)=>{d.clue=cls[i]||'RA';});
  questions=[
    {question:"What river was the lifeblood of Ancient Egypt?",answers:["Congo","Amazon","Nile","Euphrates"],correct:2},
    {question:"What were Egyptian kings called?",answers:["Emperors","Pharaohs","Sultans","Khans"],correct:1},
    {question:"What shape were royal Egyptian tombs?",answers:["Cubes","Domes","Ziggurats","Pyramids"],correct:3},
    {question:"What writing system did Egyptians use?",answers:["Latin","Runes","Hieroglyphics","Cuneiform"],correct:2},
    {question:"Which god ruled the sun?",answers:["Seth","Anubis","Osiris","Ra"],correct:3},
    {question:"Who guided souls to the afterlife?",answers:["Horus","Isis","Anubis","Bastet"],correct:2},
    {question:"What stone decoded hieroglyphics?",answers:["Obsidian","Rosetta Stone","Moonstone","Lapis"],correct:1},
    {question:"What material did Egyptians use for paper?",answers:["Cotton","Bamboo","Papyrus","Reed"],correct:2},
    {question:"What sea lay to the north of Egypt?",answers:["Red Sea","Mediterranean","Black Sea","Dead Sea"],correct:1},
    {question:"What preserved Egyptian bodies?",answers:["Freezing","Salting","Smoking","Mummification"],correct:3},
  ];
}

